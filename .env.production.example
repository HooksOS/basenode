# Production secrets & overrides for the launchpad's self-hosted Base mainnet node.
#
#   cp .env.production.example .env.production   # then fill in real values
#
# .env.production is GITIGNORED. Never commit real secrets. In production, source
# these from a secret manager (AWS Secrets Manager / Vault / SOPS), not a flat file.
#
# This file is loaded LAST via `docker compose --env-file .env.production ...`, so
# values here override .env.mainnet. Only put secrets/host-specific overrides here.

# --- L1 (Ethereum) endpoints: REQUIRED -------------------------------------
# Use a managed L1 provider or your own L1 node. Beacon endpoint is mandatory.
BASE_NODE_L1_ETH_RPC=https://<your-l1-rpc>
BASE_NODE_L1_BEACON=https://<your-l1-beacon>
# Set true only if you fully trust the L1 RPC (faster sync, weaker safety).
BASE_NODE_L1_TRUST_RPC=false

# --- Engine JWT: ROTATE THIS ------------------------------------------------
# The default in .env.mainnet is a publicly-known value. Generate a fresh secret:
#   openssl rand -hex 32
# The same value is used by both the execution and consensus processes.
BASE_NODE_L2_ENGINE_AUTH_RAW=<run: openssl rand -hex 32>

# --- Data location ----------------------------------------------------------
# Point at the NVMe/RAID mount, not the OS disk. Mainnet archive is multi-TB.
HOST_DATA_DIR=/data/base-mainnet

# --- Optional: Flashblocks (sub-200ms pending state for snappy mint/buy UX) --
# RETH_FB_WEBSOCKET_URL=wss://mainnet.flashblocks.base.org/ws
